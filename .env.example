# =============================================================================
# JohannesJohn — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any .env file with real secrets.
#
#   cp .env.example .env.local
#
# =============================================================================

# =============================================================================
# APPLICATION
# =============================================================================

# Public site name — used in page titles, headers, and SEO metadata
NEXT_PUBLIC_SITE_NAME="JohannesJohn"

# Public site URL (no trailing slash). Used by auth callbacks, document
# sharing, and email links. In development:
#   NEXT_PUBLIC_APP_URL="http://localhost:3000"
# In production:
#   NEXT_PUBLIC_APP_URL="https://johannesjohn.com"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Internal app URL (falls back to NEXT_PUBLIC_APP_URL if not set)
APP_URL=""

# Vercel-specific — set automatically in preview/production deployments
# VERCEL_URL=""
# VERCEL_ENV=""

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string (Neon, Supabase, or local)
# Example: postgres://user:password@host:5432/johannesjohn?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/johannesjohn?sslmode=require"

# Database name safety check — must match the database name in DATABASE_URL
# Used by scripts/assert-safe-database.ts to prevent accidental connections
EXPECTED_DATABASE_NAME="johannesjohn"

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Better Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# Better Auth base URL (usually same as NEXT_PUBLIC_APP_URL)
BETTER_AUTH_URL="http://localhost:3000"

# =============================================================================
# CLOUDFLARE R2 (File Storage)
# =============================================================================

# R2/S3-compatible endpoint URL
# Example: https://<accountid>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=""

# R2 Access Key ID (from R2 API Tokens page)
CLOUDFLARE_R2_ACCESS_KEY_ID=""

# R2 Secret Access Key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""

# R2 Bucket name
CLOUDFLARE_R2_BUCKET_NAME="johannesjohn"

# R2 Public URL for serving files (dev URL from R2 bucket settings)
# Example: https://pub-<hash>.r2.dev
CLOUDFLARE_R2_PUBLIC_DEV_URL=""

# =============================================================================
# EMAIL (Resend)
# =============================================================================

# Resend API key — from https://resend.com/api-keys
RESEND_API_KEY=""

# Verified sender address in Resend (e.g. "JohannesJohn <noreply@johannesjohn.com>")
RESEND_FROM_EMAIL="JohannesJohn <noreply@johannesjohn.com>"

# Reply-to address for outgoing emails
RESEND_REPLY_TO_EMAIL="sales@johannesjohn.com"

# Allow sending real emails in production (safety gate — set to "true" only when ready)
ALLOW_PRODUCTION_EMAIL="false"

# Business email for contact form notifications and fallback
BUSINESS_EMAIL="sales@johannesjohn.com"

# =============================================================================
# BUSINESS CONTACT (Defaults — overridden by dashboard settings)
# =============================================================================

# Business phone number (displayed in header and CTAs)
NEXT_PUBLIC_BUSINESS_PHONE="+264 00 000 0000"

# WhatsApp number (without + prefix, used for wa.me links)
NEXT_PUBLIC_WHATSAPP_NUMBER="264000000000"

# =============================================================================
# SECURITY
# =============================================================================

# Document share secret — used to sign public document tokens
# Generate with: openssl rand -hex 32
DOCUMENT_SHARE_SECRET=""

# System user passwords — set these in production. These are read at startup
# to create/reset the seeded admin/staff/owner accounts.
JOHANNESJOHN_OWNER_PASSWORD=""
JOHANNESJOHN_ADMIN_PASSWORD=""
JOHANNESJOHN_STAFF_PASSWORD=""

# Set to "true" to force-reset system user passwords on next bootstrap
# Do not use during normal deployments
RESET_SYSTEM_USER_PASSWORDS="false"

# =============================================================================
# WHATSAPP (Meta Business API — optional)
# =============================================================================

# WhatsApp Business Phone Number ID (from Meta Business Suite)
WHATSAPP_PHONE_NUMBER_ID=""

# WhatsApp Permanent Access Token
WHATSAPP_ACCESS_TOKEN=""

# WhatsApp Business Phone Number (for sending messages)
WHATSAPP_BUSINESS_PHONE=""

# =============================================================================
# CACHE (Upstash Redis)
# =============================================================================

# Upstash Redis REST API URL — from Upstash Console
UPSTASH_REDIS_REST_URL=""

# Upstash Redis REST API Token — from Upstash Console
UPSTASH_REDIS_REST_TOKEN=""

# Fallback env vars (Upstash provides both naming conventions)
UPSTASH_REDIS_URL=""
UPSTASH_REDIS_TOKEN=""

# =============================================================================
# MONITORING (Optional — for production)
# =============================================================================

# Sentry DSN — for error tracking in production
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# OAuth providers (optional — for staff/admin social login)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
